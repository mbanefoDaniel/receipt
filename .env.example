# Neon pooled connection string (for Prisma Client/runtime)
# Example from Neon dashboard: Connection Details -> Pooled connection
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-example-123456-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Neon direct connection string (for Prisma Migrate)
# Example from Neon dashboard: Connection Details -> Direct connection
DIRECT_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-example-123456.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Next.js auth secret (generate with: openssl rand -base64 32)
AUTH_SECRET="replace-with-long-random-string"

# Default single admin
ADMIN_EMAIL="admin@yourbusiness.com"
ADMIN_PASSWORD="Adetutu123!"

# Public site URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase (optional, used for logo upload/storage only)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET="business-assets"
